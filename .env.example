NODE_ENV=development
API_PORT=4000

# DB provider: memory | sqlite | postgres
DB_PROVIDER=memory
SQLITE_FILE_PATH=./data/condocontrol.sqlite
DATABASE_URL=
SUPABASE_DB_URL=

# AI agent / message generation
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Voice synthesis (calls)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# ElevenLabs Conversational AI Agent (for live voice support)
# Create agent at: https://elevenlabs.io/conversational-ai
ELEVENLABS_AGENT_ID=

# Twilio channels
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VOICE_FROM=+15550009999

# WhatsApp backup (Baileys)
BAILEYS_SESSION_PATH=./data/baileys-session

# Email provider
SENDGRID_API_KEY=

# Bank webhook security
BANK_WEBHOOK_SECRET=
